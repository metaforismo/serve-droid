{
  "name": "serve-droid",
  "version": "0.1.0",
  "description": "A shared browser cockpit and agent control plane for Android devices.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "author": "Francesco Giannicola",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metaforismo/serve-droid.git"
  },
  "homepage": "https://github.com/metaforismo/serve-droid#readme",
  "bugs": "https://github.com/metaforismo/serve-droid/issues",
  "keywords": [
    "android",
    "adb",
    "scrcpy",
    "mcp",
    "agent",
    "emulator",
    "device",
    "automation"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.0",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "serve-droid": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "packages/server/vendor",
    "packages/web/dist",
    "skills",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "pnpm -r build && node scripts/build-bundle.mjs",
    "clean": "pnpm -r clean",
    "dev": "pnpm --filter @serve-droid/cli dev",
    "demo": "node scripts/demo-server.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/core packages/server packages/mcp packages/cli --pretty false && pnpm --filter @serve-droid/web typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "prepack": "pnpm verify"
  },
  "dependencies": {
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "esbuild": "^0.28.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.0.17"
  }
}
